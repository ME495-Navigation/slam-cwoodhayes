<?xml version="1.0"?>
<launch>
    <!-- include one turtle of each color -->
    <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
        <arg name="use_rviz" value="false"/>
        <arg name="color" value="red"/>
    </include>
    <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
        <arg name="use_rviz" value="false"/>
        <arg name="color" value="green"/>
    </include>
    <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
        <arg name="use_rviz" value="false"/>
        <arg name="color" value="blue"/>
    </include>
    <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
        <arg name="use_rviz" value="false"/>
        <arg name="color" value="purple"/>
    </include>

    <!-- position the turtles according to the instructions -->
     <node pkg="tf2_ros" exec="static_transform_publisher"
        args="--frame-id nusim/world --child-frame-id red_base_footprint --x 0.25"
     />
     <node pkg="tf2_ros" exec="static_transform_publisher"
        args="--frame-id nusim/world --child-frame-id green_base_footprint --y 0.5"
     />
     <node pkg="tf2_ros" exec="static_transform_publisher"
        args="--frame-id nusim/world --child-frame-id blue_base_footprint --x -0.5"
     />
     <node pkg="tf2_ros" exec="static_transform_publisher"
        args="--frame-id nusim/world --child-frame-id purple_base_footprint --y -1.0"
     />

    <!-- run a single rviz instance showing all of them -->
    <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen"
        on_exit="shutdown"
        args="-d $(find-pkg-share nuturtle_description)/config/load_all.rviz"
    />
</launch>