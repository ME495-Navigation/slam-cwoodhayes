<?xml version="1.0"?>
<launch>
    <!--########################### Begin_Citation [1] #########################-->
    <!-- Launch arguments -->
    <arg name="use_rviz" default="true" description="Launch RViz for visualization" />
    <arg name="use_jsp" default="true"
        description="Launch joint_state_publisher for default joint states" />

    <!-- Get the URDF file path from turtlebot3_description package -->
    <let name="urdf_path"
        value="$(find-pkg-share turtlebot3_description)/urdf/turtlebot3_burger.urdf" />

    <!-- Read the URDF file content -->
    <let name="robot_description" value="$(command '$(exec-in-pkg xacro xacro) $(var urdf_path)')" />

    <!-- Robot State Publisher - publishes TF transforms based on URDF and joint states -->
    <node pkg="robot_state_publisher" exec="robot_state_publisher" name="robot_state_publisher"
        output="screen">
        <param name="robot_description" value="$(var robot_description)" />
    </node>

    <!-- Joint State Publisher - publishes default joint states if enabled -->
    <node pkg="joint_state_publisher" exec="joint_state_publisher" name="joint_state_publisher"
        output="screen" if="$(var use_jsp)" >
        <param name="robot_description" value="$(var robot_description)"/>
    </node>

    <!-- RViz - visualization tool -->
    <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen"
        on_exit="shutdown" if="$(var use_rviz)"
        args="-d $(find-pkg-share turtlebot3_description)/rviz/model.rviz"
        >
    </node>
    <!--########################### End_Citation [1] #########################-->

</launch>