<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <!-- args -->
  <arg name="cmd_src" default="circle" description="Source of cmd_vel commands">
    <choice value="circle"/>
    <choice value="teleop"/>
    <choice value="none"/>
  </arg>
  <arg name="robot" default="nusim" description="what robot to control (sim vs hardware etc)">
    <choice value="nusim"/>
    <choice value="localhost"/>
    <choice value="none"/>
  </arg>
  <let name="world_config" value="$(find-pkg-share nuslam)/config/slam_demo_world.yaml"/>

  <!-- start robot launch file -->
  <include file="$(find-pkg-share turtle_control)/launch/start_robot.launch.xml">
    <arg name="cmd_src" value="$(var cmd_src)"/>
    <arg name="robot" value="$(var robot)"/>
    <arg name="use_rviz" value="false"/>
    <arg name="use_odom" value="false"/>
    <arg name="nusim_world_config" value="$(var world_config)"/>
  </include>

  <!-- constants -->
  <let name="rviz_config" value="$(find-pkg-share nuslam)/config/nuslam.rviz"/>
  <let name="diff_params" value="$(find-pkg-share nuturtle_description)/config/diff_params.yaml"/>
  <let name="slam_params" value="$(find-pkg-share nuslam)/config/slam_config.yaml"/>

  <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen"
      on_exit="shutdown"
      args="-d $(var rviz_config)"/>
    
  <!-- green robot for SLAM robot estimate -->
  <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
      <arg name="use_rviz" value="false"/>
      <arg name="color" value="green"/>
      <arg name="use_jsp" value="false"/>
  </include>

  <!-- robot-specific stuff -->
  <group if="$(equals $(var robot) nusim)">
    <node pkg="nuslam" exec="slam_node" name="nuslam_node" output="screen">
      <param from="$(var diff_params)"/>
      <param from="$(var slam_params)"/>
      <param from="$(var world_config)"/>
      <param name="wheel_left" value="wheel_left_joint"/>
      <param name="wheel_right" value="wheel_right_joint"/>
      <param name="body_id" value="blue/base_footprint"/>
      <param name="odom_id" value="odom"/>
      <remap from="joint_states" to="blue/joint_states"/>
      <!-- additional params (different from odometry node) -->
      <param name="slam_body_id" value="green/base_footprint"/>
    </node>
  </group>

  <!-- TODO remove - this will be published in slam node. just adding for now to test -->
  <node pkg="tf2_ros" exec="static_transform_publisher" name="world_map_tf" args="0 0 0 0 0 0 nusim/world map"/>
</launch>