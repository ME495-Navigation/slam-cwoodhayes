<?xml version="1.0"?>
<launch>
    <arg name="config_file" default="config/basic_world.yaml" description="YAML file to configure the simulator."/>
    <let name="rviz_config" value="$(find-pkg-share nusim)/config/nusim.rviz"/>

    <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml" >
        <arg name="use_rviz" value="false"/>
        <arg name="use_jsp" value="true"/>
        <arg name="color" value="red"/>
    </include>

    <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen"
        on_exit="shutdown"
        args="-d $(var rviz_config)"
        namespace="$(var color)">
    </node>

    <node pkg="nusim" exec="nusim">
    </node>

</launch>