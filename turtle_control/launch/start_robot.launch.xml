<?xml version="1.0" encoding="UTF-8"?>
<launch>
    <arg name="cmd_src" default="circle" description="Source of cmd_vel commands">
        <choice value="circle"/>
        <choice value="teleop"/>
        <choice value="none"/>
    </arg>

    <arg name="robot" default="sim" description="what robot to control (sim vs hardware etc)">
        <choice value="sim"/>
        <choice value="localhost"/>
        <choice value="none"/>
    </arg>

    <arg name="use_rviz" default="true" description="if true, view robot behavior in RViz"/>

    <let name="rviz_config" value="$(find-pkg-share turtle_control)/config/turtle_control.rviz"/>

    <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen"
        on_exit="shutdown"
        args="-d $(var rviz_config)"/>

    <!-- rviz should always display the blue turtle -->
    <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml" >
        <arg name="use_rviz" value="false"/>
        <arg name="use_jsp" value="true"/>
        <arg name="color" value="blue"/>
    </include>

    <!-- rviz should also display the red turtle, if robot == nusim -->
    <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml" 
        if="$(equals $(var robot) sim)"
    >
        <arg name="use_rviz" value="false"/>
        <arg name="use_jsp" value="true"/>
        <arg name="color" value="red"/>
    </include>

    <node pkg="turtle_control" exec="turtle_control" name="turtle_control" output="screen">
    </node>

    <node pkg="tf2_ros" exec="static_transform_publisher" name="world_odom_tf" args="0 0 0 0 0 0 nusim/world odom"/>

</launch>