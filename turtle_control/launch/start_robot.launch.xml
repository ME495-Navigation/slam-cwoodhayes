<?xml version="1.0" encoding="UTF-8"?>
<launch>
    <!-- args & variables -->
    <arg name="cmd_src" default="circle" description="Source of cmd_vel commands">
        <choice value="circle"/>
        <choice value="teleop"/>
        <choice value="none"/>
    </arg>
    <arg name="robot" default="nusim" description="what robot to control (sim vs hardware etc)">
        <choice value="nusim"/>
        <choice value="localhost"/>
        <choice value="none"/>
    </arg>
    <arg name="use_rviz" default="true" description="if true, view robot behavior in RViz"/>
    <arg name="use_odom" default="true" description="if true, run the odometry node to publish odom based on joint states. If false, run nothing (used by slam launchfile, which runs an integrated slam+odom node)"/>
    <let name="rviz_config" value="$(find-pkg-share turtle_control)/config/turtle_control.rviz"/>
    <let name="diff_params" value="$(find-pkg-share nuturtle_description)/config/diff_params.yaml"/>
    <let name="nusim_world_config" value="$(find-pkg-share nusim)/config/basic_world.yaml"/>

    <!-- use_viz argument handling -->
    <group if="$(var use_rviz)">
        <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen"
            on_exit="shutdown"
            args="-d $(var rviz_config)"/>
    </group>

    <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
        <arg name="use_rviz" value="false"/>
        <arg name="color" value="blue"/>
        <arg name="use_jsp" value="false"/>
    </include>

    <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml" 
        if="$(equals $(var robot) nusim)"
    >
        <arg name="use_rviz" value="false"/>
        <arg name="color" value="red"/>
        <arg name="use_jsp" value="false"/>
    </include>

    <!-- static transform isn't needed by SLAM; so we disable with odom -->
    <node pkg="tf2_ros" exec="static_transform_publisher" name="world_odom_tf" args="0 0 0 0 0 0 nusim/world odom" if="$(var use_odom)"/>

    <!-- robot-specific nodes -->
    <group if="$(equals $(var robot) nusim)">
        <node pkg="nusim" exec="nusim">
            <param from="$(var nusim_world_config)"/>
            <param from="$(var diff_params)"/>
            <remap from="joint_states" to="red/joint_states"/>
        </node>

        <node pkg="turtle_control" exec="turtle_control_node" name="turtle_control" output="screen"
            on_exit="shutdown">
            <param from="$(var diff_params)"/>
            <!-- wheel commands go to the sim, sensor data comes from the sim -->
            <remap from="wheel_cmd" to="red/wheel_cmd"/>
            <remap from="sensor_data" to="red/sensor_data"/>
            <!-- joint states are published to our odom -->
            <remap from="joint_states" to="blue/joint_states"/>
        </node>
        <node pkg="turtle_control" exec="odometry" name="odometry" output="screen"
            on_exit="shutdown" if="$(var use_odom)">
            <param from="$(var diff_params)"/>
            <param name="wheel_left" value="wheel_left_joint"/>
            <param name="wheel_right" value="wheel_right_joint"/>
            <param name="body_id" value="blue/base_footprint"/>
            <param name="odom_id" value="odom"/>
            <remap from="joint_states" to="blue/joint_states"/>
        </node>

    </group>

    <!-- use this if running on the real robot -->
    <group if="$(equals $(var robot) localhost)">
        <node pkg="turtle_control" exec="turtle_control_node" name="turtle_control" output="screen"
            on_exit="shutdown">
            <param from="$(var diff_params)"/>
            <remap from="joint_states" to="blue/joint_states"/>
        </node>
        <node pkg="turtle_control" exec="odometry" name="odometry" output="screen"
            on_exit="shutdown" if="$(var use_odom)">
            <param from="$(var diff_params)"/>
            <param name="wheel_left" value="wheel_left_joint"/>
            <param name="wheel_right" value="wheel_right_joint"/>
            <param name="body_id" value="base_footprint"/>
            <param name="odom_id" value="odom"/>
            <remap from="joint_states" to="blue/joint_states"/>
        </node>
        <!-- this node only exists on the turtlebot itself. no need to depend on it; we won't use this arg on another machine -->
        <node pkg="numsr_turtlebot" exec="numsr_turtlebot"></node>

        <!-- send the base_footprint outputted by numsr_turtlebot to blue/base_footprint expected everywhere else -->
        <node pkg="tf2_ros" exec="static_transform_publisher" name="tb_base_footprint_to_blue_base_footprint" args="0 0 0 0 0 0 base_footprint blue/base_footprint"/>

        <!-- lidar -->
        <include file="$(find-pkg-share hls_lfcd_lds_driver)/launch/hlds_laser.launch.py">
            <arg name="port" value="/dev/ttyUSB0"/>
        </include>
    </group>

    <group if="$(equals $(var robot) none)">
        <!-- run nusim but only draw the landmarks -->
        <node pkg="nusim" exec="nusim"  name="nuwalls" output="screen">>
            <param name="draw_only" value="true"/>
            <param from="$(var nusim_world_config)"/>
        </node>
    </group>

    <!-- command source nodes -->
    <group if="$(equals $(var cmd_src) circle)">
        <node pkg="turtle_control" exec="circle" name="circle" output="screen"
            on_exit="shutdown">
        </node>
    </group>
    <group if="$(equals $(var cmd_src) teleop)">
        <node pkg="teleop_twist_keyboard" exec="teleop_twist_keyboard"
        name="teleop_twist_keyboard" launch-prefix="xterm -e">
        <env name="TURTLEBOT3_MODEL" value="burger" />
        </node>
    </group>
</launch>